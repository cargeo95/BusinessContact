# Google Maps Places API (New)
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=

# Consulta de búsqueda para Google Maps Text Search
# Variar por industria o zona en cada corrida para obtener resultados frescos
# Ejemplos: "agencias de marketing en Medellín", "constructoras en Cali Colombia"
MAPS_SEARCH_QUERY=empresas en Bogotá Colombia

# País por defecto cuando la dirección de la empresa no lo indica
PAIS=Colombia

# Límites de procesamiento
DAILY_COMPANY_GOAL=100
MAX_INTERNAL_PAGES=3
MAX_RANKED_EMAILS=3
COMPANY_TIMEOUT_SECONDS=8

# Groq (reservado para ranking LLM futuro)
GROQ_API_KEY=
GROQ_MODEL=
